{
  "schema_version": 1,
  "tenant_id": "example-personal-services",
  "name": "Example Personal Services Studio",
  "vertical": "personal-services",
  "brand": {
    "display_name": "Example Personal Services",
    "brand_color": "#9333EA"
  },
  "hours": {
    "timezone": "America/Vancouver",
    "schedule": {
      "monday":    null,
      "tuesday":   { "open": "10:00", "close": "18:00" },
      "wednesday": { "open": "10:00", "close": "18:00" },
      "thursday":  { "open": "10:00", "close": "18:00" },
      "friday":    { "open": "10:00", "close": "18:00" },
      "saturday":  { "open": "09:00", "close": "17:00" },
      "sunday":    null
    }
  },
  "agents": {
    "penelope": {
      "role": "penelope",
      "telegram_owner": {
        "bot_token_env": "OWNER_BOT_TOKEN",
        "owner_chat_id_env": "OWNER_CHAT_ID"
      }
    },
    "specialists": [
      { "role": "customer-frontend", "enabled": true },
      { "role": "booking",           "enabled": true },
      { "role": "quoting",           "enabled": true },
      { "role": "payment-reconciler","enabled": true },
      { "role": "review-ask",        "enabled": true },
      { "role": "marketing",         "enabled": false },
      { "role": "daily-brief",       "enabled": true }
    ]
  },
  "channels": [
    {
      "type": "telegram-owner",
      "enabled": true,
      "credential_env": "OWNER_BOT_TOKEN",
      "config": {
        "chat_id_env": "OWNER_CHAT_ID",
        "description": "Penelope — owner Telegram channel"
      }
    },
    {
      "type": "instagram-dm",
      "enabled": true,
      "credential_env": "PERSONAL_SERVICES_IG_TOKEN"
    }
  ],
  "pricing": [
    {
      "id": "single-session",
      "label": "Single appointment",
      "currency": "CAD",
      "floor": 60,
      "ceiling": 200,
      "auto_quote_band": [60, 120]
    }
  ]
}
