  "channels": [
    {
      "type": "fb-page",
      "enabled": true,
      "credential_env": "DHR_FB_PAGE_TOKEN",
      "config": {
        "page_id_env": "DHR_FB_PAGE_ID"
      }
    },
    {
      "type": "sms-textnow",
      "enabled": true,
      "credential_env": "DHR_TEXTNOW_SESSION"
    }
