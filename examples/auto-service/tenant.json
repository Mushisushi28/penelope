  "pricing": [
    {
      "id": "regular",
      "label": "Standard headlight restoration",
      "currency": "CAD",
      "floor": 99,
      "ceiling": 200,
      "auto_quote_band": [99, 150],
      "qualifier_question": "What's the make, model, and year of your vehicle, and roughly how foggy are the headlights?"
    },
    {
      "id": "ceramic",
      "label": "Ceramic-coated headlight restoration",
      "currency": "CAD",
      "floor": 200,
      "ceiling": 250,
      "auto_quote_band": [200, 240],
      "qualifier_question": "What's the make, model, and year? And are you interested in the ceramic coating that lasts 2-3x longer?"
    }
