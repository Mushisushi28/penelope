{
  "schema_version": 1,
  "tenant_id": "sample-auto-service",
  "name": "Sample Mobile Service",
  "vertical": "auto-service",
  "brand": {
    "name": "Sample Mobile Service",
    "display_name": "Sample Mobile Service",
    "brand_color": "#1E40AF",
    "tagline": "Fast, mobile service — we come to you.",
    "voice_notes": "lowercase, conversational, 1-2 sentences. no corporate speak."
  },
  "address": {
    "city": "Your City",
    "province_state": "YY",
    "country": "US"
  },
  "hours": {
    "timezone": "America/Chicago",
    "schedule": {
      "monday":    { "open": "08:00", "close": "18:00" },
      "tuesday":   { "open": "08:00", "close": "18:00" },
      "wednesday": { "open": "08:00", "close": "18:00" },
      "thursday":  { "open": "08:00", "close": "18:00" },
      "friday":    { "open": "08:00", "close": "18:00" },
      "saturday":  { "open": "09:00", "close": "16:00" },
      "sunday":    null
    }
  },
  "channels": [
    {
      "type": "fb-page",
      "enabled": true,
      "credential_env": "TENANT_FB_PAGE_TOKEN",
      "config": {
        "page_id_env": "TENANT_FB_PAGE_ID"
      }
    },
    {
      "type": "telegram-owner",
      "enabled": true,
      "credential_env": "TENANT_PENELOPE_BOT_TOKEN",
      "settings": {
        "chat_id_env": "TENANT_OWNER_CHAT_ID"
      }
    }
  ],
  "pricing": [
    {
      "id": "standard",
      "label": "Standard service",
      "currency": "USD",
      "floor": 80,
      "ceiling": 200,
      "auto_quote_band": [80, 150],
      "qualifier_question": "What make, model, and year is your vehicle?"
    },
    {
      "id": "premium",
      "label": "Premium service with extended warranty",
      "currency": "USD",
      "floor": 180,
      "ceiling": 300,
      "auto_quote_band": [180, 240],
      "qualifier_question": "Interested in the premium package with a 3-year warranty?"
    }
  ],
  "approval_gates": [
    { "action": "quote_within_band", "level": "auto" },
    { "action": "quote_above_band", "level": "owner_telegram_confirm" },
    { "action": "handle_complaint", "level": "owner_telegram_confirm" }
  ],
  "review_platforms": [
    { "type": "google", "label": "Google", "url": "https://example.com/google-review" },
    { "type": "facebook", "label": "Facebook", "url": "https://example.com/facebook-review" }
  ],
  "payment_processors": ["square"],
  "quiet_hours": {
    "enabled": true,
    "respect_business_hours": true
  },
  "budget": {
    "max_usd_per_day": 2.00,
    "max_usd_per_month": 40.00,
    "alert_threshold_pct": 80
  },
  "connectors": {
    "booking": {
      "provider": "calendly",
      "url_env": "TENANT_CALENDLY_URL"
    },
    "square": {
      "access_token_secret": "TENANT_SQUARE_ACCESS_TOKEN",
      "location_id_secret": "TENANT_SQUARE_LOCATION_ID"
    }
  },
  "followup": {
    "enabled": true,
    "min_days_silent": 7,
    "max_days_silent": 180,
    "approval_required": true,
    "stages": ["quoted_no_booking", "booked_no_show", "paid_rebook"]
  },
  "content": {
    "enabled": false,
    "providers": { "image_gen": "fal-ai", "vision": "claude" },
    "watermark_targets": [],
    "object_removal_defaults": ["tape", "masking tape", "tools", "hands"],
    "output_folder": "sorted"
  }
}
