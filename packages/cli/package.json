{
  "name": "@penelope/cli",
  "version": "0.1.0-alpha.1",
  "description": "Penelope install CLI — scaffold and run your tenant in 90 seconds",
  "license": "MIT",
  "author": "Isaac Dobson",
  "homepage": "https://github.com/Mushisushi28/penelope#readme",
  "repository": {
    "type": "git",
    "url": "https://github.com/Mushisushi28/penelope.git"
  },
  "bugs": "https://github.com/Mushisushi28/penelope/issues",
  "type": "module",
  "engines": { "node": ">=20" },
  "bin": {
    "penelope": "./bin/penelope.mjs"
  },
  "files": [
    "dist",
    "bin"
  ],
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "import": "./dist/index.js",
      "types": "./dist/index.d.ts"
    }
  },
  "scripts": {
    "build": "tsc",
    "dev": "tsc --watch",
    "test": "vitest run",
    "test:watch": "vitest",
    "lint": "tsc --noEmit",
    "prepublishOnly": "npm run build && npm test",
    "postinstall": "node dist/postinstall.js 2>/dev/null || true"
  },
  "dependencies": {
    "@inquirer/prompts": "^5.5.0",
    "chalk": "^5.3.0",
    "commander": "^12.1.0",
    "js-yaml": "^4.1.0",
    "ora": "^8.1.0"
  },
  "devDependencies": {
    "@types/js-yaml": "^4.0.9",
    "@types/node": "^20.14.0",
    "typescript": "^5.4.5",
    "vitest": "^1.6.0"
  },
  "peerDependencies": {
    "@penelope/adapters": "*",
    "@penelope/agents": "*",
    "@penelope/core": "*"
  },
  "peerDependenciesMeta": {
    "@penelope/adapters": { "optional": true },
    "@penelope/agents": { "optional": true },
    "@penelope/core": { "optional": true }
  },
  "publishConfig": {
    "access": "public"
  },
  "keywords": ["penelope", "telegram", "small-business", "cli", "scaffold", "agents"]
}
