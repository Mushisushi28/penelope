{
  "name": "@penelope/agents",
  "version": "0.1.0",
  "description": "Owner-agent (CEO bot) + meta-router + specialist agents for Penelope",
  "license": "MIT",
  "type": "module",
  "exports": {
    ".": {
      "import": "./dist/index.js",
      "types": "./dist/index.d.ts"
    },
    "./meta-router": {
      "import": "./dist/owner-agent/meta-router.js",
      "types": "./dist/owner-agent/meta-router.d.ts"
    },
    "./specialists/*": {
      "import": "./dist/specialists/*.js",
      "types": "./dist/specialists/*.d.ts"
    }
  },
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "files": ["dist", "src"],
  "scripts": {
    "build": "tsc",
    "test": "vitest run",
    "test:watch": "vitest",
    "lint": "tsc --noEmit",
    "clean": "rm -rf dist"
  },
  "dependencies": {
    "nunjucks": "^3.2.4",
    "zod": "^3.23.8"
  },
  "devDependencies": {
    "@types/nunjucks": "^3.2.6",
    "@types/node": "^20.14.0",
    "typescript": "^5.4.5",
    "vitest": "^1.6.0"
  },
  "engines": {
    "node": ">=20"
  }
}
