{
  "name": "@penelope/adapters",
  "version": "0.1.0",
  "description": "Reusable channel adapters for Penelope tenants (Telegram, FB Messenger, Twilio SMS, IMAP/SMTP email, Instagram stub, Loom A2A)",
  "license": "MIT",
  "type": "module",
  "exports": {
    ".": {
      "import": "./dist/index.js",
      "types": "./dist/index.d.ts"
    }
  },
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "tsc",
    "test": "vitest run",
    "test:watch": "vitest",
    "lint": "tsc --noEmit"
  },
  "dependencies": {
    "imapflow": "^1.0.166",
    "nodemailer": "^6.9.14"
  },
  "devDependencies": {
    "@types/better-sqlite3": "^7.6.10",
    "@types/node": "^20.14.0",
    "@types/nodemailer": "^6.4.15",
    "typescript": "^5.4.5",
    "vitest": "^1.6.0"
  },
  "peerDependencies": {
    "@penelope/core": ">=0.1.0"
  },
  "peerDependenciesMeta": {
    "@penelope/core": {
      "optional": true
    }
  },
  "engines": {
    "node": ">=20"
  },
  "keywords": [
    "penelope",
    "channel-adapter",
    "telegram",
    "facebook-messenger",
    "twilio",
    "sms",
    "imap",
    "smtp",
    "email",
    "instagram",
    "loom-a2a"
  ],
  "optionalDependencies": {
    "better-sqlite3": "^9.6.0"
  }
}
