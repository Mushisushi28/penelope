{
  "name": "@penelope/procedure-eval",
  "version": "0.1.0",
  "description": "Procedure replay harness — test a procedure against a recorded conversation thread",
  "license": "MIT",
  "author": "Isaac Dobson",
  "type": "module",
  "exports": {
    ".": {
      "import": "./dist/index.js",
      "types": "./dist/index.d.ts"
    },
    "./replay": {
      "import": "./dist/replay.js",
      "types": "./dist/replay.d.ts"
    },
    "./recorder": {
      "import": "./dist/recorder.js",
      "types": "./dist/recorder.d.ts"
    },
    "./types": {
      "import": "./dist/types.js",
      "types": "./dist/types.d.ts"
    }
  },
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "files": ["dist"],
  "scripts": {
    "build": "tsc",
    "test": "vitest run",
    "test:watch": "vitest",
    "lint": "tsc --noEmit"
  },
  "devDependencies": {
    "@types/node": "^20.14.0",
    "typescript": "^5.4.5",
    "vitest": "^1.6.0"
  },
  "engines": {
    "node": ">=20"
  }
}
