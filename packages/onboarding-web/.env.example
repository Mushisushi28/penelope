# Penelope onboarding-web environment variables
# Copy to .env.local for local development

# Optional: base URL of a running Penelope instance.
# When set, Step 5's "Push to instance" button forwards the tenant config here.
# PENELOPE_INSTANCE_URL=https://penelope.myshop.com

# Optional: secret sent as Bearer token with the forwarded install request.
# Generate: openssl rand -hex 32
# PENELOPE_INSTALL_SECRET=

# Optional: analytics measurement ID (Plausible or GA4)
# NEXT_PUBLIC_ANALYTICS_ID=

# Optional: canonical URL for OG tags (defaults to Vercel deployment URL)
# NEXT_PUBLIC_APP_URL=https://setup.penelope.ai
