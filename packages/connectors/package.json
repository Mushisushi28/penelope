{
  "name": "@penelope/connectors",
  "version": "0.2.0-alpha.1",
  "description": "5-tier connector architecture for Penelope — MCP, API-skill, Hermes OpenAPI, browser, computer-use",
  "license": "MIT",
  "author": "Isaac Dobson",
  "homepage": "https://github.com/Mushisushi28/penelope#readme",
  "repository": {
    "type": "git",
    "url": "https://github.com/Mushisushi28/penelope.git"
  },
  "bugs": "https://github.com/Mushisushi28/penelope/issues",
  "type": "module",
  "engines": { "node": ">=20" },
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "import": "./dist/index.js",
      "types": "./dist/index.d.ts"
    },
    "./types": {
      "import": "./dist/types.js",
      "types": "./dist/types.d.ts"
    },
    "./registry": {
      "import": "./dist/registry.js",
      "types": "./dist/registry.d.ts"
    }
  },
  "files": [
    "dist",
    "src",
    "state"
  ],
  "scripts": {
    "build": "tsc",
    "dev": "tsc --watch",
    "test": "vitest run",
    "test:watch": "vitest",
    "lint": "tsc --noEmit",
    "prepublishOnly": "npm run build && npm test"
  },
  "dependencies": {
    "@penelope/secrets": "^0.2.0-alpha.1"
  },
  "devDependencies": {
    "@types/node": "^20.14.0",
    "typescript": "^5.4.5",
    "vitest": "^1.6.0"
  },
  "publishConfig": {
    "access": "public"
  },
  "keywords": [
    "penelope",
    "connectors",
    "mcp",
    "openapi",
    "hermes",
    "computer-use",
    "automation",
    "small-business"
  ]
}
