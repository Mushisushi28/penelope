# ─────────────────────────────────────────────────────────────────────────────
# Penelope — environment variables
# Copy this file to .env and fill in your values.
#   cp .env.example .env
# Never commit .env to version control.
# ─────────────────────────────────────────────────────────────────────────────

# ── Core ─────────────────────────────────────────────────────────────────────

# Where Penelope stores tenant databases, state, and logs.
# Docker: leave as /data (volume-mounted). Bare metal: absolute path on disk.
PENELOPE_DATA_DIR=./data

# TCP port the dashboard HTTP server listens on.
PENELOPE_DASHBOARD_PORT=18900

# Log verbosity: error | warn | info | debug
LOG_LEVEL=info

# ── Owner Telegram bot ────────────────────────────────────────────────────────
# The bot that receives owner commands and sends owner briefs.
# Get a token: https://t.me/BotFather → /newbot → copy the token.
OWNER_TELEGRAM_BOT_TOKEN=

# Your personal Telegram user ID (not the bot ID).
# Open https://t.me/userinfobot, start it, it replies with your numeric ID.
OWNER_TELEGRAM_CHAT_ID=

# ── Facebook / Meta (per default tenant slot) ─────────────────────────────────
# Page Access Token for your Facebook Business Page.
# Get one: Meta Business Suite → Settings → Advanced → Page Access Tokens
# OR: graph.facebook.com/me/accounts?access_token=<user-token>
# Scope required: pages_messaging, pages_read_engagement
FB_PAGE_ACCESS_TOKEN=

# Facebook Page ID (numeric). Shown in the About section of your Page
# or via: graph.facebook.com/me?fields=id&access_token=<page-token>
FB_PAGE_ID=

# Facebook App Verify Token — a random string YOU choose; must match
# what you enter in the Meta Developers webhook settings.
FB_VERIFY_TOKEN=

# ── Stripe ────────────────────────────────────────────────────────────────────
# Stripe secret key — starts with sk_live_ (production) or sk_test_ (test mode).
# Dashboard → Developers → API keys
STRIPE_SECRET_KEY=

# Stripe webhook signing secret — used to verify incoming webhook events.
# Dashboard → Developers → Webhooks → your endpoint → Signing secret
STRIPE_WEBHOOK_SECRET=

# ── Twilio (SMS) ─────────────────────────────────────────────────────────────
# Twilio Account SID — starts with AC. Console → Dashboard.
TWILIO_ACCOUNT_SID=

# Twilio Auth Token — same page as Account SID.
TWILIO_AUTH_TOKEN=

# Twilio phone number in E.164 format, e.g. +14155552671
# Console → Phone Numbers → Manage → Active numbers
TWILIO_FROM_NUMBER=

# ── Email (SMTP) ──────────────────────────────────────────────────────────────
# SMTP credentials for outbound email (quotes, invoices, review asks).
# Gmail: use App Passwords (not your main password) — myaccount.google.com → Security → App Passwords
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=
SMTP_PASS=

# Displayed "From" name and address on outgoing emails.
SMTP_FROM_NAME=
SMTP_FROM_EMAIL=

# ── Optional: Postgres (uncomment if using local Postgres instead of Neon) ───
# DATABASE_URL=postgresql://penelope:secret@localhost:5432/penelope
# POSTGRES_PASSWORD=changeme

# ── Optional: domain (needed for nginx TLS service) ──────────────────────────
# PENELOPE_DOMAIN=penelope.yourdomain.com
# OWNER_EMAIL=you@yourdomain.com
